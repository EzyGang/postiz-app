# === Misc Settings
OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"  # Optional: Custom OpenAI-compatible API endpoint (OpenRouter, LocalAI, Ollama, etc.)
# OPENAI_CHAT_MODEL="gpt-4.1"  # Optional: Override default chat model
# OPENAI_IMAGE_MODEL="dall-e-3"  # Optional: Override default image generation model

# Image Generation Provider (Optional - allows using a different provider for images)
# If not set, uses the same provider as chat (OPENAI_BASE_URL)
# OPENAI_IMAGE_BASE_URL="https://api.openai.com/v1"  # Custom image generation endpoint (Fal.ai, Replicate, etc.)
# OPENAI_IMAGE_API_KEY=""  # Optional: Different API key for image generation
NEXT_PUBLIC_DISCORD_SUPPORT=
NEXT_PUBLIC_POLOTNO=
API_LIMIT=30

# === Payment / Stripe Settings
FEE_AMOUNT=0.05
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_KEY=
STRIPE_SIGNING_KEY_CONNECT=

# === Developer Settings
NX_ADD_PLUGINS=false

# === Short Link Service Settings (uncomment to use)
# DUB_TOKEN=
# DUB_API_ENDPOINT=https://api.dub.co
# DUB_SHORT_LINK_DOMAIN=dub.sh
# SHORT_IO_SECRET_KEY=
# KUTT_API_KEY=
# KUTT_API_ENDPOINT=https://kutt.it/api/v2
# KUTT_SHORT_LINK_DOMAIN=kutt.it
# LINK_DRIP_API_KEY=
# LINK_DRIP_API_ENDPOINT=https://api.linkdrip.com/v1/
# LINK_DRIP_SHORT_LINK_DOMAIN=dripl.ink

# ============================================
# Postiz PostgreSQL
# ============================================
POSTGRES_PASSWORD=postiz-password
POSTGRES_USER=postiz-user
POSTGRES_DB=postiz-db-local

# ============================================
# Temporal Elasticsearch
# ============================================
cluster.routing.allocation.disk.threshold_enabled=true
cluster.routing.allocation.disk.watermark.low=512mb
cluster.routing.allocation.disk.watermark.high=256mb
cluster.routing.allocation.disk.watermark.flood_stage=128mb
discovery.type=single-node
ES_JAVA_OPTS=-Xms256m -Xmx256m
xpack.security.enabled=false

# ============================================
# Temporal PostgreSQL
# ============================================
TEMPORAL_POSTGRES_PASSWORD=temporal
TEMPORAL_POSTGRES_USER=temporal

# ============================================
# Temporal Server
# ============================================
DB=postgres12
DB_PORT=5432
POSTGRES_SEEDS=temporal-postgresql
DYNAMIC_CONFIG_FILE_PATH=config/dynamicconfig/development-sql.yaml
ENABLE_ES=true
ES_SEEDS=temporal-elasticsearch
ES_VERSION=v7
TEMPORAL_NAMESPACE=default

# ============================================
# Temporal Admin Tools
# ============================================
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_CLI_ADDRESS=temporal:7233

# ============================================
# Temporal UI
# ============================================
TEMPORAL_UI_ADDRESS=temporal:7233
TEMPORAL_CORS_ORIGINS=http://127.0.0.1:3000
